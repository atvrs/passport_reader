# Example environment file for passport-reader.service.
# Copy this file to:
#
#   /etc/passport-reader/passport-reader.env
#
# Then edit values for your installation.
#
# Do not commit the real production env file to git.

PASSPORT_READER_DATA_DIR=/data/passport_reader

PASSPORT_READER_OCR_MAX_SIDE=1800

PASSPORT_READER_ARCHIVE_RETENTION_DAYS=30
PASSPORT_READER_ARCHIVE_MAX_GB=5

PASSPORT_READER_OUT_RETENTION_DAYS=7

PASSPORT_READER_LOG_TOTAL_MAX_MB=100
PASSPORT_READER_LOG_FILES_COUNT=5

PASSPORT_READER_HEARTBEAT_SEC=10
